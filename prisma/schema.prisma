generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Veiculo {
  id           String     @id @default(uuid())
  placa        String     @unique
  modelo       String
  ano          Int
  kmInicial    Float
  kmFinal      Float?
  capacidadeKg Float
  ativo        Boolean @default(true)
  romaneios    Romaneio[]
  kmHistorico  VeiculoKm[]
  createdAt    DateTime   @default(now())
}

model VeiculoKm {

  id         String   @id @default(uuid())

  veiculoId  String
  veiculo    Veiculo  @relation(fields: [veiculoId], references: [id])

  kmSaida    Int
  kmRetorno  Int?
  kmRodado   Int?

  dataSaida  DateTime @default(now())
  dataRetorno DateTime?
}


model Motorista {
  id        String     @id @default(uuid())
  nome      String
  cnh       String     @unique
  endereco  String
  telefone  String
  romaneios Romaneio[]
  createdAt DateTime   @default(now())
}

model Cliente {
  id           String @id @default(uuid())
  ativo             Boolean
  nomeFantasia      String?
  telefone          String?
  contato           String?
  email             String?
  cidade            String?
  estado            String?
  endereco          String?
  cep               String?
  inscricaoEstadual String?

  latitude          Float?
  longitude         Float?

  entregas Entrega[]

  createdAt     DateTime       @default(now())
  itemRomaneios ItemRomaneio[]
}

model Produto {
  id        String   @id @default(uuid())
  nome      String
  createdAt DateTime @default(now())

  itensEntrega ItemEntrega[]

  embalagens    Embalagem[]
  itemRomaneios ItemRomaneio[]
}

model Embalagem {
  id             String @id @default(uuid())
  descricao      String
  unidades       Int
  pesoUnitarioKg Float

  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id])

  itensEntrega ItemEntrega[]

  itensRomaneio ItemRomaneio[]

  createdAt DateTime @default(now())
}

model ItemRomaneio {
  id String @id @default(uuid())

  romaneioId String
  romaneio   Romaneio @relation(fields: [romaneioId], references: [id])

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id])

  embalagemId String
  embalagem   Embalagem @relation(fields: [embalagemId], references: [id])

  quantidade Int

  observacao String?

  status String @default("PENDENTE")
}

model Romaneio {
  id String @id @default(uuid())

  motoristaId String
  motorista   Motorista @relation(fields: [motoristaId], references: [id])

  veiculoId String
  veiculo   Veiculo @relation(fields: [veiculoId], references: [id])

  dataSaida DateTime
  dataFim   DateTime?

  status String @default("ABERTO")

  entregas      Entrega[]
  itensRomaneio ItemRomaneio[]

  createdAt DateTime @default(now())
}

model Entrega {
  id String @id @default(uuid())

  romaneioId String
  romaneio   Romaneio @relation(fields: [romaneioId], references: [id])

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  status String @default("PENDENTE")

  dataEntrega DateTime?

  itens ItemEntrega[]

  observacao String?

  createdAt DateTime @default(now())
}

model ItemEntrega {
  id String @id @default(uuid())

  entregaId String
  entrega   Entrega @relation(fields: [entregaId], references: [id])

  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id])

  embalagemId String
  embalagem   Embalagem @relation(fields: [embalagemId], references: [id])

  quantidade Int
}

