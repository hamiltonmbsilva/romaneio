generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Veiculo {
  id            String   @id @default(uuid())
  placa         String   @unique
  modelo        String
  ano           Int
  kmInicial     Float
  kmFinal       Float?
  capacidadeKg  Float
  romaneios     Romaneio[]
  createdAt     DateTime @default(now())
}

model Motorista {
  id         String   @id @default(uuid())
  nome       String
  cnh        String   @unique
  endereco   String
  telefone   String
  romaneios  Romaneio[]
  createdAt  DateTime @default(now())
}

model Cliente {
  id           String   @id @default(uuid())
  nomeFantasia String
  bairro       String
  rua          String
  numero       String
  cep          String
  telefone     String
  createdAt    DateTime @default(now())
}

model Romaneio {
  id               String   @id @default(uuid())
  numero           String
  data             DateTime
  rota             String
  dataAgendamento  DateTime
  ticket           String?
  numeroNF         String?
  totalPeso        Float

  veiculoId        String
  motoristaId      String

  veiculo          Veiculo   @relation(fields: [veiculoId], references: [id])
  motorista        Motorista @relation(fields: [motoristaId], references: [id])

  produtos         ProdutoRomaneio[]

  createdAt        DateTime @default(now())
}

model ProdutoRomaneio {
  id            String  @id @default(uuid())
  descricao     String
  quantidade    Float
  pesoUnitario  Float
  pesoTotal     Float

  romaneioId    String
  romaneio      Romaneio @relation(fields: [romaneioId], references: [id])
}
